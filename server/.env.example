# ── Server ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# ── Auth (FR-02, NFR Security) ─────────────────────────────────────────
# JWT access token expires after 1 hour per SRS 4.2; refresh token is long-lived.
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-another-long-random-string
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=30d

# ── PostgreSQL (SRS 10.1) ──────────────────────────────────────────────
DATABASE_URL=postgres://dalili:dalili@localhost:5432/dalili
# (Docker compose sets these automatically.)

# ── Redis cache (SRS 10.2) — optional; falls back to in-memory ─────────
REDIS_URL=

# ── Weather providers (FR-13, FR-14) ───────────────────────────────────
TOMORROW_API_KEY=
OPENWEATHER_API_KEY=
WEATHER_CACHE_TTL_SECONDS=900        # 15 minutes (FR-16)
WEATHER_POLL_CRON=*/10 * * * *       # poll loop for alert evaluation

# ── Google Maps Platform (FR-09, FR-11, FR-42) ─────────────────────────
# Server key (Geocoding API). The browser uses a separate key (client/.env).
GOOGLE_MAPS_API_KEY=

# ── Push notifications: Firebase Cloud Messaging (FR-25) ───────────────
FCM_SERVER_KEY=

# ── SMS alerts (FR-26): choose ONE provider ────────────────────────────
# Africa's Talking is the easy option for Kenya: it delivers to
# Safaricom/Airtel/Telkom, bills in KES, and has a free sandbox
# (username "sandbox") — sign up at https://africastalking.com.
SMS_PROVIDER=africastalking          # africastalking | twilio | none
# Africa's Talking
AT_USERNAME=                         # "sandbox" for testing
AT_API_KEY=
AT_SENDER_ID=                        # optional registered sender ID, e.g. DALILI
# Twilio (alternative)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Email notifications (FR-27) ────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Dalili Weather <alerts@dalili.app>"
