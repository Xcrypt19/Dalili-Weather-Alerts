# --- Dalili SMS backend (Africa's Talking) ---
# Copy this file to server/.env and fill in your real values.
# These are SECRET and must never be committed or exposed to the browser.

# Your Africa's Talking username. Use "sandbox" while testing.
AT_USERNAME=sandbox

# Your Africa's Talking API key (Dashboard → Settings → API Key).
AT_API_KEY=

# Optional registered sender ID / short code. Leave blank to use the default.
AT_SENDER_ID=

# "sandbox" for the test environment, "live" for production sending.
AT_ENV=sandbox

# Port the SMS backend listens on (matches the Vite dev proxy target).
SMS_PORT=8787
