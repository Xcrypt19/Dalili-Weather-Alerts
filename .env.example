# --- Dalili front-end (build-time) ---
# Copy this file to .env and fill in what you need. Both are OPTIONAL:
# the app runs fully without them.
#
# IMPORTANT: anything prefixed VITE_ is embedded in the browser bundle and is
# therefore PUBLIC. Only put publishable keys here — never secrets.
# (Africa's Talking credentials live in server/.env, not here.)

# Google Maps JavaScript API key. Without it, the Map view shows the styled
# Kenya overview instead of a live Google Map. Restrict the key to your domains
# in the Google Cloud console.
VITE_GOOGLE_MAPS_API_KEY=

# Where the app sends SMS requests. Defaults to /api/sms (the bundled backend,
# proxied in dev and same-origin in production). Override only if your SMS
# backend lives at a different URL.
VITE_SMS_ENDPOINT=/api/sms
